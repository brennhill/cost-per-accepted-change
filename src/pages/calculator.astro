---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Calculator"
  description="Calculate cost per accepted change. Enter your numbers, get a shareable result."
  path="/calculator"
>
  <article class="page">
    <p class="eyebrow">Calculator</p>
    <h1>Compute cost per accepted change</h1>
    <p class="lede">
      Enter the costs and counts for one measurement window — a sprint, a month, a quarter. The calculator runs entirely in your browser; nothing is sent to a server.
    </p>

    <noscript>
      <div class="callout">
        <span class="label">JavaScript required</span>
        This calculator runs entirely in your browser, but it does require JavaScript. With JavaScript disabled, compute cost per accepted change manually using the formula on the <a href="/">definition page</a> or the <a href="/faq">git-based recipe in the FAQ</a>.
      </div>
    </noscript>

    <form class="calc-form" id="cpac-form" autocomplete="off">
      <fieldset>
        <legend class="sr-only">Measurement window inputs</legend>

        <div class="calc-row">
          <div>
            <label for="modelCost">Model cost</label>
            <span class="hint" id="modelCost-hint">LLM / API spend attributable to the changes produced. Tools like <a href="https://github.com/git-ai-project/git-ai">git-ai</a> can help attribute model spend to specific commits.</span>
          </div>
          <input id="modelCost" name="modelCost" type="number" inputmode="decimal" min="0" step="0.01" value="1200" aria-describedby="modelCost-hint" />
        </div>

        <div class="calc-row">
          <div>
            <label for="infraCost">Infrastructure cost</label>
            <span class="hint" id="infraCost-hint">Compute, storage, observability, tooling overhead.</span>
          </div>
          <input id="infraCost" name="infraCost" type="number" inputmode="decimal" min="0" step="0.01" value="400" aria-describedby="infraCost-hint" />
        </div>

        <div class="calc-row">
          <div>
            <label for="engineeringTime">Engineering time</label>
            <span class="hint" id="engineeringTime-hint">Spec / prompt / integrate / steer, converted to currency.</span>
          </div>
          <input id="engineeringTime" name="engineeringTime" type="number" inputmode="decimal" min="0" step="0.01" value="18000" aria-describedby="engineeringTime-hint" />
        </div>

        <div class="calc-row">
          <div>
            <label for="reviewCost">Review cost</label>
            <span class="hint" id="reviewCost-hint">Time spent reviewing / gating AI work, converted to currency.</span>
          </div>
          <input id="reviewCost" name="reviewCost" type="number" inputmode="decimal" min="0" step="0.01" value="6000" aria-describedby="reviewCost-hint" />
        </div>

        <div class="calc-row">
          <div>
            <label for="reworkCost">Rework cost</label>
            <span class="hint" id="reworkCost-hint">Cost of fixing or reverting changes that did not stay in production.</span>
          </div>
          <input id="reworkCost" name="reworkCost" type="number" inputmode="decimal" min="0" step="0.01" value="2400" aria-describedby="reworkCost-hint" />
        </div>

        <div class="calc-row">
          <div>
            <label for="acceptedChanges">Accepted changes</label>
            <span class="hint" id="acceptedChanges-hint">Whole-number count of changes that reached production <strong>and stayed there</strong> during the window.</span>
          </div>
          <input id="acceptedChanges" name="acceptedChanges" type="number" inputmode="numeric" min="1" step="1" value="42" aria-describedby="acceptedChanges-hint" />
        </div>
      </fieldset>
    </form>

    <div class="calc-result" id="result">
      <span class="label">Cost per accepted change</span>
      <span class="value" id="result-value" aria-live="polite">—</span>
      <div class="breakdown" id="result-breakdown" aria-hidden="true"></div>
    </div>

    <div class="calc-actions">
      <button type="button" class="btn btn-primary" id="copy-link">Copy shareable link</button>
      <a class="btn" href="https://github.com/brennhill/cost-per-accepted-change/blob/main/src/lib/calculator.ts">View source (main branch)</a>
    </div>

    <h2>Use the library</h2>
    <p>
      The calculator is a pure TypeScript function. Import it in your own dashboards, FinOps pipelines, or CI jobs:
    </p>
<pre><code>import &#123; costPerAcceptedChange &#125; from 'cost-per-accepted-change';

const cpac = costPerAcceptedChange(&#123;
  modelCost: 1200,
  infraCost: 400,
  engineeringTime: 18000,
  reviewCost: 6000,
  reworkCost: 2400,
  acceptedChanges: 42,
&#125;);

console.log(cpac.value);     // 666.67
console.log(cpac.breakdown); // share-of-total per component
</code></pre>
    <p>
      Source: <a href="https://github.com/brennhill/cost-per-accepted-change">github.com/brennhill/cost-per-accepted-change</a>. MIT-licensed.
    </p>
  </article>

  <script>
    import {
      costPerAcceptedChange,
      formatCurrency,
      formatShare,
      type CPACInputs,
    } from '../lib/calculator';

    const form = document.getElementById('cpac-form') as HTMLFormElement;
    const valueEl = document.getElementById('result-value') as HTMLElement;
    const breakdownEl = document.getElementById('result-breakdown') as HTMLElement;
    const copyBtn = document.getElementById('copy-link') as HTMLButtonElement;

    const fieldNames = [
      'modelCost',
      'infraCost',
      'engineeringTime',
      'reviewCost',
      'reworkCost',
      'acceptedChanges',
    ] as const;

    function readInputs(): CPACInputs {
      const data: Record<string, number> = {};
      for (const name of fieldNames) {
        const input = form.elements.namedItem(name) as HTMLInputElement;
        const raw = input.value;
        data[name] = raw === '' ? 0 : Number(raw);
      }
      return data as unknown as CPACInputs;
    }

    function compute() {
      try {
        const inputs = readInputs();
        const result = costPerAcceptedChange(inputs);
        valueEl.textContent = formatCurrency(result.value);
        breakdownEl.textContent =
          `Total cost: ${formatCurrency(result.totalCost)} ÷ ${result.acceptedChanges} accepted changes. ` +
          `Model ${formatShare(result.breakdown.modelCost)} · ` +
          `Infra ${formatShare(result.breakdown.infraCost)} · ` +
          `Eng ${formatShare(result.breakdown.engineeringTime)} · ` +
          `Review ${formatShare(result.breakdown.reviewCost)} · ` +
          `Rework ${formatShare(result.breakdown.reworkCost)}`;
      } catch (err) {
        valueEl.textContent = '—';
        breakdownEl.textContent = err instanceof Error ? err.message : 'Enter values to compute.';
      }
    }

    // Debounce keystroke-driven recomputes so screen readers and the result
    // region aren't pummeled with intermediate states on every keypress.
    function debounce<T extends (...args: never[]) => void>(fn: T, ms: number): T {
      let handle: number | undefined;
      return ((...args: never[]) => {
        if (handle !== undefined) window.clearTimeout(handle);
        handle = window.setTimeout(() => fn(...args), ms);
      }) as T;
    }
    const debouncedCompute = debounce(compute, 300);

    function syncFromUrl() {
      const params = new URLSearchParams(window.location.search);
      for (const name of fieldNames) {
        if (params.has(name)) {
          const input = form.elements.namedItem(name) as HTMLInputElement;
          input.value = params.get(name) ?? '';
        }
      }
    }

    function buildShareUrl() {
      const inputs = readInputs() as unknown as Record<string, number>;
      const params = new URLSearchParams();
      for (const name of fieldNames) {
        params.set(name, String(inputs[name]));
      }
      return `${window.location.origin}${window.location.pathname}?${params.toString()}`;
    }

    syncFromUrl();
    compute();
    form.addEventListener('input', debouncedCompute);

    copyBtn.addEventListener('click', async () => {
      const url = buildShareUrl();
      try {
        await navigator.clipboard.writeText(url);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied ✓';
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 1600);
      } catch {
        window.prompt('Copy this URL:', url);
      }
    });
  </script>
</BaseLayout>
