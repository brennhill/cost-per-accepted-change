---
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/400-italic.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-serif-4/600-italic.css';
import '../styles/global.css';
import Mark from '../components/Mark.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
  /** Open Graph type. Default 'article'; pass 'website' for the homepage. */
  ogType?: 'article' | 'website';
}

const {
  title,
  description = "Cost per accepted change: the canonical definition, calculator, and reference for measuring the true cost of producing trusted software.",
  path = '/',
  ogType = 'article',
} = Astro.props;

const fullTitle = title === 'Cost per accepted change'
  ? title
  : `${title} — Cost per accepted change`;

const canonical = `https://costperacceptedchange.org${path === '/' ? '' : path}`;
const ogImage = 'https://costperacceptedchange.org/og-image.png';
const ogImageAlt = 'Cost per accepted change — the fully-loaded cost of producing software that stayed in production, divided by the number of changes that did.';

const nav = [
  { href: '/', label: 'Definition' },
  { href: '/start', label: 'Start' },
  { href: '/calculator', label: 'Calculator' },
  { href: '/use', label: 'Use' },
  { href: '/instrument', label: 'Instrument' },
  { href: '/templates', label: 'Templates' },
  { href: '/measurement', label: 'Compare' },
  { href: '/faq', label: 'FAQ' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta name="theme-color" content="#fbfaf6" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Cost Per Accepted Change" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site">
      <div class="inner">
        <a href="/" class="brand" aria-label="Cost Per Accepted Change — home">
          <Mark size={30} class="brand-mark" ariaHidden={true} />
          <span class="brand-text">Cost Per Accepted Change</span>
        </a>
        <nav aria-label="Main">
          {nav.map((item) => (
            <a
              href={item.href}
              aria-current={path === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <!--
      Analytics — both cookieless, no consent banner needed.
      Cloudflare Web Analytics is auto-injected via the Pages dashboard.
      GoatCounter is the script tag below. CSP allowlists for both are
      in public/_headers.
    -->
    <script
      data-goatcounter="https://costperacceptedchange.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"
    ></script>
    <footer class="site">
      <div class="inner">
        <div class="col">
          <span class="footer-byline">
            Defined by <a href="https://www.linkedin.com/in/brennhill/">Brenn Hill</a> in <em>The Delivery Gap</em> (2026). <a href="/cite">Cite</a> · <a href="/press">Press</a>.
          </span>
          <span class="footer-meta">
            Subscribe at <a href="https://brennhill.substack.com">brennhill.substack.com</a>.
          </span>
        </div>
        <div class="col col-right">
          <a href="https://github.com/brennhill/cost-per-accepted-change">Source on GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
