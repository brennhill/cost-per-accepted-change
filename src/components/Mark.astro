---
interface Props {
  size?: number;
  class?: string;
  title?: string;
  /**
   * When true, the mark is treated as purely decorative — no role, no title,
   * no aria-label. Use when the parent element already has an accessible name
   * (e.g. a brand link with its own aria-label).
   */
  ariaHidden?: boolean;
}

const {
  size = 32,
  class: className,
  title = 'Cost per accepted change',
  ariaHidden = false,
} = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  xmlns="http://www.w3.org/2000/svg"
  role={ariaHidden ? undefined : 'img'}
  aria-label={ariaHidden ? undefined : title}
  aria-hidden={ariaHidden ? 'true' : undefined}
  focusable={ariaHidden ? 'false' : undefined}
  class={className}
>
  {!ariaHidden && <title>{title}</title>}
  <text
    x="32"
    y="27"
    text-anchor="middle"
    font-family="Source Serif 4, Iowan Old Style, Charter, Georgia, serif"
    font-size="22"
    font-weight="600"
    fill="currentColor"
  >$</text>
  <line
    x1="12"
    y1="33"
    x2="52"
    y2="33"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linecap="round"
  />
  <text
    x="32"
    y="53"
    text-anchor="middle"
    font-family="Source Serif 4, Iowan Old Style, Charter, Georgia, serif"
    font-size="18"
    font-weight="600"
    fill="currentColor"
  >AC</text>
</svg>
