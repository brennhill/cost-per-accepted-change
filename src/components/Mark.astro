---
interface Props {
  size?: number;
  class?: string;
  title?: string;
}

const { size = 32, class: className, title = 'Cost per accepted change' } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={title}
  class={className}
>
  <title>{title}</title>
  <text
    x="32"
    y="27"
    text-anchor="middle"
    font-family="Iowan Old Style, Charter, Georgia, serif"
    font-size="22"
    font-weight="600"
    fill="currentColor"
  >$</text>
  <line
    x1="12"
    y1="33"
    x2="52"
    y2="33"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linecap="round"
  />
  <text
    x="32"
    y="53"
    text-anchor="middle"
    font-family="Iowan Old Style, Charter, Georgia, serif"
    font-size="18"
    font-weight="600"
    fill="currentColor"
  >AC</text>
</svg>
